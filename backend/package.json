{
  "name": "spaghetti-backend",
  "version": "1.0.0",
  "description": "Backend API for SPAGHETTI design automation platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["design", "automation", "ai", "api"],
  "author": "SPAGHETTI Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "envalid": "^8.0.0",
    "zod": "^3.23.8",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0",
    "uuid": "^9.0.1",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "swagger-ui-express": "^5.0.0",
    "@asteasolutions/zod-to-openapi": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.1",
    "ts-jest": "^29.2.0",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "supertest": "^7.0.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "pino-pretty": "^11.0.0"
  }
}
